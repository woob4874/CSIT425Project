# Auth0 application settings
# Copy this file to .env and fill in your values from the Auth0 dashboard.

# Your Auth0 tenant domain (e.g. dev-xxxxxxxx.us.auth0.com)
VITE_AUTH0_DOMAIN=your-tenant.auth0.com

# The Client ID of your Auth0 Single Page Application
VITE_AUTH0_CLIENT_ID=your-auth0-client-id

# The API audience (identifier) — only required if you are calling a backend API
VITE_AUTH0_AUDIENCE=https://your-api-identifier

# Base URL for your backend REST API
VITE_API_URL=http://localhost:3001
